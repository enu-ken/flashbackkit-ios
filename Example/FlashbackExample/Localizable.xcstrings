      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイテム %lld"
          }
        }
      }
    },
    "Dummy row — scroll to see motion" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダミー行 — スクロールで動きを確認"
