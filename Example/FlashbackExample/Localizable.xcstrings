    },
    "Priming read flag reset. Tap the FAB while recording is off (gray) to show it again." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライミング既読をリセットしました。録画オフ（グレー）の FAB をタップで再表示。"
          }
        }
      }
    },
