    "Recording ON — ring buffer running" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "録画 ON — リングバッファ動作中"
          }
        }
      }
    },
    "Recording OFF — toggle via the floating button to compare" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "録画 OFF — フローティングボタンで切り替えて比較"
